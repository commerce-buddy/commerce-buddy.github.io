---
import type { T } from "../data/content";
import Icon from "./Icon.astro";

interface Props { t: T; }
const { t } = Astro.props;
---
<section class="section" id="pricing" style="background: var(--bg-2)">
  <div class="wrap">
    <div class="section-head" style="text-align: center; margin: 0 auto">
      <div class="eyebrow" style="justify-content: center">{t.pricing.eyebrow}</div>
      <h2 class="h2">{t.pricing.title}</h2>
      <p class="lede" style="margin: 0 auto">{t.pricing.lede}</p>
    </div>

    <div class="price-grid">
      {t.pricing.plans.map((p) => {
        const featured = p.key === "yearly";
        return (
          <div class={`price ${featured ? "pro" : "free"}`}>
            <div class="price-name">
              {p.name}
              {p.ribbon ? <span class="ribbon">{p.ribbon}</span> : null}
            </div>
            <div class="price-amount">
              <span class="num" style={featured ? "color: #fff" : undefined}>{p.amount}</span>
              <span class="per">{p.per}</span>
              {p.strike ? <span class="strike">{p.strike}</span> : null}
            </div>
            <div class="price-badge">{p.badge}</div>
            <div class="price-first">{p.firstLine}</div>
            <div class="price-sub">{p.sub}</div>
            {featured ? (
              <a class="btn btn-primary btn-lg" href="#install">
                <Icon name="bolt" size={15} />
                {p.cta}
              </a>
            ) : (
              <a class="btn btn-ghost btn-lg" href="#install">{p.cta}</a>
            )}
          </div>
        );
      })}
    </div>

    <div class="price-includes">
      <div class="price-includes-title">{t.pricing.featsTitle}</div>
      <ul class="price-includes-list">
        {t.pricing.feats.map((f) => (
          <li>
            <Icon name="check" size={14} />
            <span>{f}</span>
          </li>
        ))}
      </ul>
    </div>
  </div>
</section>
